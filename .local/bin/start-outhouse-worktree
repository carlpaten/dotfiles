#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: $(basename "$0") <linear-issue-key>" >&2
    exit 1
fi

ISSUE_KEY="$1"
MAIN_WORKTREE_PATH="$HOME/macrosoft"
OPEN_WORKTREE_SCRIPT="$HOME/.scripts/open-desktop-worktree.sh"
REFERENCE_URL="https://outlook.office.com"

die() {
    echo "$1" >&2
    exit 1
}

require_command() {
    local cmd="$1"
    local message="${2:-$cmd not found in PATH.}"
    command -v "$cmd" >/dev/null 2>&1 || die "$message"
}

slugify() {
    local value="$1"
    printf '%s' "$value" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g'
}

find_free_port() {
    local port="${1:-3002}"
    while [[ $port -le 65535 ]]; do
        if command -v ss >/dev/null 2>&1; then
            if ! ss -Htan "( sport = :$port )" 2>/dev/null | grep -q . \
                && ! ss -Huan "( sport = :$port )" 2>/dev/null | grep -q .; then
                printf '%s\n' "$port"
                return 0
            fi
        elif command -v lsof >/dev/null 2>&1; then
            if ! lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1; then
                printf '%s\n' "$port"
                return 0
            fi
        elif command -v netstat >/dev/null 2>&1; then
            if ! netstat -an 2>/dev/null | awk '{print $4}' | grep -Eq "[:.]$port$"; then
                printf '%s\n' "$port"
                return 0
            fi
        else
            printf '%s\n' "$port"
            return 0
        fi
        port=$((port + 1))
    done
    return 1
}

next_available_branch() {
    local repo_root="$1"
    local base="$2"
    local branch="$base"
    local counter=2
    while git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; do
        branch="${base}-${counter}"
        counter=$((counter + 1))
    done
    printf '%s\n' "$branch"
}

ensure_worktree() {
    local repo_root="$1"
    local worktree_path="$2"
    local branch_to_create="$3"
    local start_point="$4"

    if [[ -e "$worktree_path" ]]; then
        if git -C "$worktree_path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
            local existing_branch
            existing_branch="$(git -C "$worktree_path" rev-parse --abbrev-ref HEAD)"
            printf 'reused|%s\n' "$existing_branch"
            return 0
        fi
        die "Target path exists and is not a git worktree: $worktree_path"
    fi

    git -C "$repo_root" worktree add -b "$branch_to_create" "$worktree_path" "$start_point" >/dev/null
    printf 'created|%s\n' "$branch_to_create"
}

ensure_tmux_window_macos() {
    local tmux_window_name="$1"
    local worktree_path="$2"
    local dev_port="$3"
    local dev_command
    local current_pane
    local current_session
    local window_id
    local top_pane
    local bottom_pane

    [[ -n "${TMUX:-}" ]] || die "On macOS, run this command from inside an existing tmux session."

    dev_command="cd \"$worktree_path\" && pnpm install && (printf 'a\\n\\n' | pnpm approve-builds || true) && PORT=\"$dev_port\" pnpm dev:outhouse -- --port \"$dev_port\""
    current_pane="${TMUX_PANE:-}"
    [[ -n "$current_pane" ]] || die "Unable to determine the current tmux pane."
    current_session="$(tmux display-message -p -t "$current_pane" '#S' 2>/dev/null || true)"
    [[ -n "$current_session" ]] || die "Unable to determine the current tmux session."

    window_id="$(tmux list-windows -t "$current_session" -F '#{window_id} #{window_name}' \
        | awk -v target="$tmux_window_name" '$2 == target { print $1; exit }')"

    if [[ -z "$window_id" ]]; then
        window_id="$(tmux new-window -P -F '#{window_id}' -t "$current_session:" -n "$tmux_window_name" -c "$worktree_path")"
    fi

    local pane_count
    local bottom_command
    top_pane="$(tmux list-panes -t "$window_id" -F '#{pane_id}' | head -n1)"
    [[ -n "$top_pane" ]] || die "Failed to determine tmux pane for window $tmux_window_name."
    pane_count="$(tmux list-panes -t "$window_id" -F '#{pane_id}' | wc -l | tr -d ' ')"

    tmux send-keys -t "$top_pane" C-c
    tmux send-keys -t "$top_pane" "cd \"$worktree_path\"" C-m

    if [[ "${pane_count:-0}" -lt 2 ]]; then
        bottom_pane="$(tmux split-window -v -P -F '#{pane_id}' -t "$top_pane" -c "$worktree_path")"
    else
        bottom_pane="$(tmux list-panes -t "$window_id" -F '#{pane_id}' | tail -n1)"
    fi

    bottom_command="$(tmux display-message -p -t "$bottom_pane" '#{pane_current_command}' || true)"
    if [[ "$bottom_command" == "bash" || "$bottom_command" == "zsh" || "$bottom_command" == "sh" || "$bottom_command" == "fish" ]]; then
        tmux send-keys -t "$bottom_pane" C-c
    fi
    tmux send-keys -t "$bottom_pane" "$dev_command" C-m
    tmux select-layout -t "$window_id" even-vertical >/dev/null 2>&1 || true
    tmux select-window -t "$window_id" >/dev/null 2>&1 || true

    printf '%s|%s|%s\n' "$current_session" "$window_id" "$bottom_pane"
}

tmux_dev_pane_exited_macos() {
    local dev_pane="$1"
    local pane_command last_line

    if ! tmux list-panes -a -F '#{pane_id}' | grep -Fxq "$dev_pane"; then
        return 1
    fi

    pane_command="$(tmux display-message -p -t "$dev_pane" '#{pane_current_command}' || true)"
    if [[ "$pane_command" != "bash" && "$pane_command" != "zsh" && "$pane_command" != "sh" && "$pane_command" != "fish" ]]; then
        return 1
    fi

    last_line="$(tmux capture-pane -pt "$dev_pane" -S -20 | sed '/^[[:space:]]*$/d' | tail -n1)"
    [[ "$last_line" == *'% ' || "$last_line" == *'$ ' || "$last_line" == *'# ' ]]
}

capture_tmux_dev_pane_macos() {
    local dev_pane="$1"

    if ! tmux list-panes -a -F '#{pane_id}' | grep -Fxq "$dev_pane"; then
        return 1
    fi

    tmux capture-pane -pt "$dev_pane" -S -80
}

open_worktree_macos() {
    local main_worktree_path="$1"
    local issue_key="$2"

    require_command git "git not found in PATH."
    require_command tmux "tmux not found in PATH."
    require_command pnpm "pnpm not found in PATH."

    local main_repo_root
    main_repo_root="$(git -C "$main_worktree_path" rev-parse --show-toplevel 2>/dev/null || true)"
    [[ -n "$main_repo_root" ]] || die "Path is not inside a git worktree: $main_worktree_path"

    local repo_name parent_dir issue_slug dev_port worktree_name worktree_path
    repo_name="$(basename "$main_repo_root")"
    parent_dir="$(dirname "$main_repo_root")"
    issue_slug="$(slugify "$issue_key")"
    [[ -n "$issue_slug" ]] || die "Issue key produced an empty slug: $issue_key"
    dev_port="$(find_free_port 3002 || true)"
    [[ -n "$dev_port" ]] || die "Unable to determine a free development port."

    worktree_name="${repo_name}-${issue_slug}"
    worktree_path="${parent_dir}/${worktree_name}"

    git -C "$main_repo_root" fetch --quiet origin dev || die "Failed to fetch origin/dev from $main_repo_root"

    local branch_base branch_to_create worktree_result branch_name reused_worktree tmux_window_name tmux_window_result tmux_session tmux_window_id dev_pane
    branch_base="feature/${repo_name}-${issue_slug}"
    branch_to_create="$(next_available_branch "$main_repo_root" "$branch_base")"
    worktree_result="$(ensure_worktree "$main_repo_root" "$worktree_path" "$branch_to_create" "origin/dev")"
    branch_name="${worktree_result#*|}"
    reused_worktree="false"
    if [[ "${worktree_result%%|*}" == "reused" ]]; then
        reused_worktree="true"
    fi

    tmux_window_name="desk-${repo_name}-${issue_slug}"
    tmux_window_result="$(ensure_tmux_window_macos "$tmux_window_name" "$worktree_path" "$dev_port")"
    tmux_session="${tmux_window_result%%|*}"
    tmux_window_result="${tmux_window_result#*|}"
    tmux_window_id="${tmux_window_result%%|*}"
    dev_pane="${tmux_window_result##*|}"

    echo "Created worktree: $worktree_path"
    echo "Created branch: $branch_name"
    if [[ "$reused_worktree" == "true" ]]; then
        echo "Reused existing worktree directory."
    fi
    echo "Using tmux session: $tmux_session"
    echo "Using tmux window: $tmux_window_name"
    echo "Tmux window id: $tmux_window_id"
    echo "Dev pane: $dev_pane"
    echo "Assigned dev port: $dev_port"
}

wait_for_server() {
    local port="$1"
    local timeout_seconds="${2:-120}"
    local dev_pane="${3:-}"
    local elapsed=0

    while (( elapsed < timeout_seconds )); do
        if curl -s --max-time 2 "http://localhost:${port}/api/v1/me/mailFolders" >/dev/null 2>&1; then
            return 0
        fi
        if [[ -n "$dev_pane" ]] && tmux_dev_pane_exited_macos "$dev_pane"; then
            return 2
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    return 1
}

wait_for_file() {
    local path="$1"
    local timeout_seconds="${2:-120}"
    local dev_pane="${3:-}"
    local elapsed=0

    while (( elapsed < timeout_seconds )); do
        if [[ -x "$path" ]]; then
            return 0
        fi
        if [[ -n "$dev_pane" ]] && tmux_dev_pane_exited_macos "$dev_pane"; then
            return 2
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    return 1
}

if [[ "$(uname -s)" == "Darwin" ]]; then
    OPEN_OUTPUT="$(open_worktree_macos "$MAIN_WORKTREE_PATH" "$ISSUE_KEY")"
else
    OPEN_OUTPUT="$($OPEN_WORKTREE_SCRIPT --reference-url "$REFERENCE_URL" "$MAIN_WORKTREE_PATH" "$ISSUE_KEY")"
fi
printf '%s\n' "$OPEN_OUTPUT"

DEV_PORT="$(printf '%s\n' "$OPEN_OUTPUT" | awk -F': ' '/Assigned dev port:/ {print $2; exit}')"
if [[ -z "$DEV_PORT" ]]; then
    echo "Warning: Could not determine assigned dev port. Skipping db seed." >&2
    exit 0
fi

REPO_NAME="$(basename "$MAIN_WORKTREE_PATH")"
PARENT_DIR="$(dirname "$MAIN_WORKTREE_PATH")"
ISSUE_SLUG="$(slugify "$ISSUE_KEY")"
WORKTREE_PATH="${PARENT_DIR}/${REPO_NAME}-${ISSUE_SLUG}"
TMUX_DEV_PANE="$(printf '%s\n' "$OPEN_OUTPUT" | awk -F': ' '/Dev pane:/ {print $2; exit}')"

if [[ ! -d "$WORKTREE_PATH" ]]; then
    echo "Warning: Worktree path not found at $WORKTREE_PATH. Skipping db seed." >&2
    exit 0
fi

TOOLS_WAIT_RESULT=0
wait_for_file "$WORKTREE_PATH/node_modules/.bin/tsx" 120 "$TMUX_DEV_PANE" || TOOLS_WAIT_RESULT=$?
if [[ "$TOOLS_WAIT_RESULT" -eq 2 ]]; then
    echo "Warning: Dev pane ${TMUX_DEV_PANE:-unknown} exited before dependencies finished installing. Skipping db seed." >&2
    capture_tmux_dev_pane_macos "$TMUX_DEV_PANE" >&2 || true
    exit 0
fi
if [[ "$TOOLS_WAIT_RESULT" -ne 0 ]]; then
    echo "Warning: Dependencies for $WORKTREE_PATH did not finish installing in time. Skipping db seed." >&2
    exit 0
fi

WAIT_RESULT=0
wait_for_server "$DEV_PORT" 120 "$TMUX_DEV_PANE" || WAIT_RESULT=$?
if [[ "$WAIT_RESULT" -eq 2 ]]; then
    echo "Warning: Dev pane ${TMUX_DEV_PANE:-unknown} exited before the server became reachable. Skipping db seed." >&2
    capture_tmux_dev_pane_macos "$TMUX_DEV_PANE" >&2 || true
    exit 0
fi

if [[ "$WAIT_RESULT" -ne 0 ]]; then
    echo "Warning: Dev server on port $DEV_PORT did not become reachable in time. Skipping db seed." >&2
    exit 0
fi

echo "Seeding database for $WORKTREE_PATH via http://localhost:$DEV_PORT ..."
(
    cd "$WORKTREE_PATH"
    OUTHOUSE_URL="http://localhost:${DEV_PORT}" pnpm db:seed -- -pick mail
)
