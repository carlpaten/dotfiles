#!/usr/bin/env bash
set -euo pipefail

MODEL_DEFAULT="openai-codex/gpt-5.3-codex"
MCP_PACKAGE_DEFAULT="@playwright/mcp@0.0.68"
WORKDIR_DEFAULT="$HOME"
STORAGE_STATE_DEFAULT="$HOME/.config/playwright-mcp/shared-storage-state.json"
DEBUG_VIDEO_SIZE_DEFAULT="1280x720"
OUTLOOK_EMAIL_DEFAULT="carlpaten@protonmail.com"

MODEL="${PI_MODEL:-$MODEL_DEFAULT}"
MCP_PACKAGE="$MCP_PACKAGE_DEFAULT"
WORKDIR="$WORKDIR_DEFAULT"
STORAGE_STATE_PATH="${PLAYWRIGHT_STORAGE_STATE_PATH:-$STORAGE_STATE_DEFAULT}"
HEADLESS="true"
KEEP_SECRETS="false"
TARGET_URL=""
BW_ITEMS=()
DEBUG_VIDEO_DIR=""
DEBUG_VIDEO_SIZE="$DEBUG_VIDEO_SIZE_DEFAULT"
OUTLOOK_EMAIL="${OUTLOOK_TARGET_EMAIL:-$OUTLOOK_EMAIL_DEFAULT}"

TMP_DIR=""
SECRETS_FILE=""
PROMPT_FILE=""
RUNNER_FILE=""

usage() {
  cat <<'USAGE'
Usage:
  pi-playwright-signin-state-from-bitwarden --url <signin-url> --bw-item <item-id-or-name> [--bw-item <item> ...] [options]

Options:
  --url <signin-url>         Sign-in URL to open.
  --bw-item <item>           Bitwarden item ID or name. Can be repeated.
  --storage-state <path>     Storage-state output path (default: ~/.config/playwright-mcp/shared-storage-state.json).
  --model <model>            pi model (default: openai-codex/gpt-5.3-codex).
  --mcp-package <pkg>        Playwright MCP package/version (default: @playwright/mcp@0.0.68).
  --workdir <path>           Working directory for codex exec (default: $HOME).
  --outlook-email <email>    Required Outlook account email (default: carlpaten@protonmail.com).
  --debug-video-dir <path>   Enable debug artifacts (video/trace/session) in this directory.
  --debug-video-size <wxh>   Video size for --save-video (default: 1280x720).
  --headed                   Run browser headed.
  --headless                 Run browser headless (default).
  --keep-secrets             Keep generated secrets file for debugging (default: false).
  -h, --help                 Show this help.

Requirements:
  - bw CLI logged in/unlockable
  - jq, pi, codex, npx
USAGE
}

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: required command not found: $cmd" >&2
    exit 1
  fi
}

sanitize_key() {
  local raw="$1"
  local key
  key="$(printf '%s' "$raw" | tr '[:lower:]' '[:upper:]' | sed -E 's/[^A-Z0-9]+/_/g; s/^_+//; s/_+$//; s/__+/_/g')"
  if [[ -z "$key" ]]; then
    key="SECRET"
  fi
  printf '%s\n' "$key"
}

dotenv_quote() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  printf '"%s"' "$value"
}

cleanup() {
  local exit_code=$?
  if [[ "${KEEP_SECRETS}" != "true" && -n "${SECRETS_FILE}" && -f "${SECRETS_FILE}" ]]; then
    rm -f "${SECRETS_FILE}"
  fi
  if [[ -n "${PROMPT_FILE}" && -f "${PROMPT_FILE}" ]]; then
    rm -f "${PROMPT_FILE}"
  fi
  if [[ -n "${RUNNER_FILE}" && -f "${RUNNER_FILE}" ]]; then
    rm -f "${RUNNER_FILE}"
  fi
  if [[ -n "${TMP_DIR}" && -d "${TMP_DIR}" ]]; then
    rmdir "${TMP_DIR}" 2>/dev/null || true
  fi
  exit "${exit_code}"
}
trap cleanup EXIT INT TERM

while [[ $# -gt 0 ]]; do
  case "$1" in
    --url)
      TARGET_URL="${2:-}"
      shift 2
      ;;
    --bw-item)
      BW_ITEMS+=("${2:-}")
      shift 2
      ;;
    --storage-state)
      STORAGE_STATE_PATH="${2:-}"
      shift 2
      ;;
    --model)
      MODEL="${2:-}"
      shift 2
      ;;
    --mcp-package)
      MCP_PACKAGE="${2:-}"
      shift 2
      ;;
    --workdir)
      WORKDIR="${2:-}"
      shift 2
      ;;
    --outlook-email)
      OUTLOOK_EMAIL="${2:-}"
      shift 2
      ;;
    --debug-video-dir)
      DEBUG_VIDEO_DIR="${2:-}"
      shift 2
      ;;
    --debug-video-size)
      DEBUG_VIDEO_SIZE="${2:-}"
      shift 2
      ;;
    --headed)
      HEADLESS="false"
      shift
      ;;
    --headless)
      HEADLESS="true"
      shift
      ;;
    --keep-secrets)
      KEEP_SECRETS="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

if [[ -z "${TARGET_URL}" ]]; then
  echo "Error: --url is required." >&2
  exit 1
fi
if [[ "${#BW_ITEMS[@]}" -eq 0 ]]; then
  echo "Error: at least one --bw-item is required." >&2
  exit 1
fi

target_url_lc="$(printf '%s' "${TARGET_URL}" | tr '[:upper:]' '[:lower:]')"
enforce_outlook_account="false"
if [[ "${target_url_lc}" == *"outlook.office.com"* || "${target_url_lc}" == *"outlook.live.com"* || "${target_url_lc}" == *"login.live.com"* || "${target_url_lc}" == *"login.microsoftonline.com"* ]]; then
  enforce_outlook_account="true"
fi

require_cmd bw
require_cmd jq
require_cmd pi
require_cmd codex
require_cmd npx

BW_SESSION_TOKEN="${BW_SESSION:-}"
if [[ -z "${BW_SESSION_TOKEN}" ]]; then
  if [[ ! -f "${HOME}/bitwarden_unlock" ]]; then
    echo "Error: ~/bitwarden_unlock is required and was not found." >&2
    exit 1
  fi
  # shellcheck source=/dev/null
  source "${HOME}/bitwarden_unlock"
  BW_SESSION_TOKEN="${BW_SESSION:-}"
  if [[ -z "${BW_SESSION_TOKEN}" ]]; then
    echo "Error: ~/bitwarden_unlock did not set BW_SESSION." >&2
    exit 1
  fi
fi

bw sync --session "${BW_SESSION_TOKEN}" >/dev/null

TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/pi-playwright-signin-state-XXXXXX")"
SECRETS_FILE="${TMP_DIR}/secrets.env"
PROMPT_FILE="${TMP_DIR}/codex-prompt.txt"
RUNNER_FILE="${TMP_DIR}/run-codex-signin-state.sh"
mkdir -p "$(dirname "${STORAGE_STATE_PATH}")"
touch "${SECRETS_FILE}"
chmod 600 "${SECRETS_FILE}"

declare -A WRITTEN_KEYS=()
declare -A PREFIX_COUNTS=()
declare -a SECRET_KEYS=()

append_secret() {
  local key="$1"
  local value="$2"
  if [[ -z "${value}" ]]; then
    return
  fi
  if [[ -n "${WRITTEN_KEYS[$key]:-}" ]]; then
    return
  fi
  printf '%s=%s\n' "$key" "$(dotenv_quote "$value")" >> "${SECRETS_FILE}"
  WRITTEN_KEYS["$key"]=1
  SECRET_KEYS+=("$key")
}

first_item="true"
selected_item_count=0
outlook_email_lc="$(printf '%s' "${OUTLOOK_EMAIL}" | tr '[:upper:]' '[:lower:]')"
for item_ref in "${BW_ITEMS[@]}"; do
  item_json="$(bw get item "${item_ref}" --session "${BW_SESSION_TOKEN}")"

  item_name="$(jq -r '.name // "item"' <<<"${item_json}")"
  prefix_base="$(sanitize_key "${item_name}")"
  count="${PREFIX_COUNTS[$prefix_base]:-0}"
  count="$((count + 1))"
  PREFIX_COUNTS["$prefix_base"]="${count}"
  if [[ "${count}" -eq 1 ]]; then
    prefix="${prefix_base}"
  else
    prefix="${prefix_base}_${count}"
  fi

  username="$(jq -r '.login.username // empty' <<<"${item_json}")"
  password="$(jq -r '.login.password // empty' <<<"${item_json}")"
  totp="$(jq -r '.login.totp // empty' <<<"${item_json}")"
  username_lc="$(printf '%s' "${username}" | tr '[:upper:]' '[:lower:]')"

  if [[ "${enforce_outlook_account}" == "true" && "${username_lc}" != "${outlook_email_lc}" ]]; then
    continue
  fi

  selected_item_count="$((selected_item_count + 1))"

  append_secret "${prefix}_USERNAME" "${username}"
  append_secret "${prefix}_PASSWORD" "${password}"
  append_secret "${prefix}_TOTP" "${totp}"

  while IFS=$'\t' read -r field_name field_value; do
    field_key="$(sanitize_key "${field_name}")"
    append_secret "${prefix}_${field_key}" "${field_value}"
  done < <(jq -r '.fields[]? | select((.value // "") != "") | [(.name // "FIELD"), .value] | @tsv' <<<"${item_json}")

  if [[ "${first_item}" == "true" ]]; then
    append_secret "USERNAME" "${username}"
    append_secret "PASSWORD" "${password}"
    append_secret "TOTP" "${totp}"
    if [[ "${username}" == *"@"* ]]; then
      append_secret "EMAIL" "${username}"
    fi
    first_item="false"
  fi
done

if [[ "${selected_item_count}" -eq 0 ]]; then
  echo "Error: no secrets extracted from the provided Bitwarden items." >&2
  exit 1
fi

if [[ "${enforce_outlook_account}" == "true" ]]; then
  append_secret "OUTLOOK_TARGET_EMAIL" "${OUTLOOK_EMAIL}"
fi

{
  printf 'Use Playwright MCP to open this URL and complete sign-in: %s\n\n' "${TARGET_URL}"
  printf 'Use only the provisioned secret placeholders below when typing form values.\n'
  printf 'Do not print or transform secret values; pass placeholder keys directly to browser tools.\n\n'
  printf 'Hard stop condition:\n'
  printf -- '- Do not stop after filling credentials; you must complete login flow.\n'
  printf -- '- Handle post-login prompts (for example, \"Stay signed in?\") and reach an authenticated app UI.\n'
  if [[ "${enforce_outlook_account}" == "true" ]]; then
    printf -- '- If prompted with account chooser, use OUTLOOK_TARGET_EMAIL.\n'
  fi
  printf '\n'
  if [[ "${enforce_outlook_account}" == "true" ]]; then
    printf 'Outlook account requirement:\n'
    printf -- '- You must sign in as %s only.\n' "${OUTLOOK_EMAIL}"
    printf -- '- If a different account appears, choose \"Use another account\" and continue with OUTLOOK_TARGET_EMAIL.\n\n'
  fi
  printf 'Success criteria before finishing:\n'
  if [[ "${enforce_outlook_account}" == "true" ]]; then
    printf -- '- URL starts with https://outlook.live.com/mail/ or https://outlook.office.com/mail/\n'
    printf -- '- Mail UI is visible (Inbox or folders pane is present)\n'
    printf -- '- Authentication interstitials are gone\n\n'
  else
    printf -- '- URL is no longer on the sign-in domain\n'
    printf -- '- Authenticated app UI is visible\n'
    printf -- '- Authentication interstitials are gone\n\n'
  fi
  printf 'After success, save storage state using browser_storage_state to this exact path:\n'
  printf '%s\n\n' "${STORAGE_STATE_PATH}"
  printf 'Then verify the file exists and is non-empty via bash: test -s %q\n\n' "${STORAGE_STATE_PATH}"
  printf 'Available secret keys:\n'
  for key in "${SECRET_KEYS[@]}"; do
    printf -- '- %s\n' "${key}"
  done
} > "${PROMPT_FILE}"

mcp_args_config="mcp_servers.playwright.args=[\"${MCP_PACKAGE}\",\"--secrets\",\"${SECRETS_FILE}\""
if [[ "${HEADLESS}" == "true" ]]; then
  mcp_args_config="${mcp_args_config},\"--headless\""
fi
if [[ -n "${DEBUG_VIDEO_DIR}" ]]; then
  mkdir -p "${DEBUG_VIDEO_DIR}"
  mcp_args_config="${mcp_args_config},\"--output-dir\",\"${DEBUG_VIDEO_DIR}\""
  mcp_args_config="${mcp_args_config},\"--save-video=${DEBUG_VIDEO_SIZE}\""
  mcp_args_config="${mcp_args_config},\"--save-trace\""
  mcp_args_config="${mcp_args_config},\"--save-session\""
fi
mcp_args_config="${mcp_args_config}]"

cat > "${RUNNER_FILE}" <<EOF
#!/usr/bin/env bash
set -euo pipefail
codex exec \
  --dangerously-bypass-approvals-and-sandbox \
  --skip-git-repo-check \
  -C ${WORKDIR@Q} \
  -c 'mcp_servers.playwright.command="npx"' \
  -c 'mcp_servers.playwright.startup_timeout_sec=120' \
  -c ${mcp_args_config@Q} \
  - < ${PROMPT_FILE@Q}
EOF
chmod 700 "${RUNNER_FILE}"

PI_PROMPT="$(cat <<EOF
Run this exact shell command and return only its output (stdout/stderr), with no extra commentary:
${RUNNER_FILE}
EOF
)"

pi --model "${MODEL}" --print --no-session --tools bash "${PI_PROMPT}"

if [[ ! -s "${STORAGE_STATE_PATH}" ]]; then
  echo "Error: storage state was not created or is empty: ${STORAGE_STATE_PATH}" >&2
  exit 1
fi

if ! jq -e '
  (.cookies | type == "array") and
  (.origins | type == "array")
' "${STORAGE_STATE_PATH}" >/dev/null 2>&1; then
  echo "Error: storage state file is not valid Playwright storage JSON: ${STORAGE_STATE_PATH}" >&2
  exit 1
fi

cookies_count="$(jq -r '.cookies | length' "${STORAGE_STATE_PATH}")"
origins_count="$(jq -r '.origins | length' "${STORAGE_STATE_PATH}")"
echo "Storage state verified: ${STORAGE_STATE_PATH} (cookies=${cookies_count}, origins=${origins_count})" >&2

if [[ "${KEEP_SECRETS}" == "true" ]]; then
  echo "Kept secrets file for debugging: ${SECRETS_FILE}" >&2
fi
